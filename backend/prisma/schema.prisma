generator client {
	provider = "prisma-client-js"
}

datasource db {
	provider = "mysql"
	url      = env("DATABASE_URL")
}

enum Theme {
	dark
	light
}

enum ColorTheme {
	red
	blue
	purple
	gold
}

enum Language {
	en
	lt
}

enum PlayerType {
	user
	bot
}

enum GameStatus {
	lobby
	in_progress
	finished
	cancelled
}

enum TieBehavior {
	no_one_dies
	random_among_tied
	revote
}

enum VoteCountVisibility {
	never
	end
	live
}

enum RoleAlignment {
	vampire
	commune
	neutral
}

enum PhaseType {
	day
	voting
	night
}

enum RoleDistributionMode {
	exact
	weighted_random
}

model UserPlayer {
	playerId Int @id
	userId   Int @unique

	player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
	user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BotPlayer {
	playerId Int @id
	botId    Int @unique

	player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
	bot    Bot    @relation(fields: [botId], references: [id], onDelete: Cascade)
}

model User {
	id       Int    @id @default(autoincrement())
	username String @unique
	email    String @unique
	password String

	theme      Theme      @default(dark)
	colorTheme ColorTheme @default(red)
	language   Language   @default(en)

	createdAt DateTime @default(now())
	updatedAt DateTime @updatedAt

	session    Session?
	userPlayer UserPlayer?
}

model Session {
	id               Int      @id @default(autoincrement())
	userId           Int      @unique
	refreshTokenHash String
	refreshExpiresAt DateTime

	createdAt DateTime @default(now())
	updatedAt DateTime @updatedAt

	user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bot {
	id   Int    @id @default(autoincrement())
	name String @unique

	createdAt DateTime @default(now())
	updatedAt DateTime @updatedAt

	botPlayer BotPlayer?
}

model Player {
	id       Int        @id @default(autoincrement())
	type     PlayerType

	icon     String?    @db.MediumText
	iconEtag String?

	createdAt DateTime @default(now())
	updatedAt DateTime @updatedAt

	user UserPlayer?
	bot  BotPlayer?

	participants Participant[]
}

model Game {
	id       Int        @id @default(autoincrement())
	gameCode String     @unique
	status   GameStatus @default(lobby)

	maxPlayers Int @db.SmallInt @default(10)
	minPlayers Int @db.SmallInt @default(5)

	phaseType     PhaseType?
	daySeconds    Int @db.SmallInt @default(60)
	votingSeconds Int @db.SmallInt @default(30)
	nightSeconds  Int @db.SmallInt @default(60)

	tieBehavior          TieBehavior          @default(no_one_dies)
	voteCountVisibility  VoteCountVisibility  @default(end)
	anonymousVoting      Boolean              @default(false)
	roleRevealOnDeath    Boolean              @default(true)
	roleDistributionMode RoleDistributionMode @default(exact)

	createdAt DateTime @default(now())
	updatedAt DateTime @updatedAt

	participants Participant[]
	roleSetup    GameRoleSetup[]
}

model GameRoleSetup {
	id Int @id @default(autoincrement())

	gameId Int
	roleId Int
	count  Int? @db.SmallInt

	game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
	role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

	createdAt DateTime @default(now())
	updatedAt DateTime @updatedAt

	@@unique([gameId, roleId])
	@@index([gameId])
	@@index([roleId])
}

model Role {
	id        Int           @id @default(autoincrement())
	key       String        @unique
	alignment RoleAlignment
	weight    Int           @db.SmallInt

	createdAt DateTime @default(now())
	updatedAt DateTime @updatedAt

	gameSetupEntries GameRoleSetup[]
	participants     Participant[]
}

model Participant {
	gameId   Int
	playerId Int
	seatNr   Int
	roleId   Int?

	game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
	player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
	role   Role?  @relation(fields: [roleId], references: [id])

	@@id([gameId, playerId])
	@@unique([gameId, seatNr])
	@@index([playerId])
	@@index([roleId])
	@@index([gameId])
}